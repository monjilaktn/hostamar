NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
DATABASE_URL=postgresql://user:pass@host/db
JWT_SECRET=your-jwt-secret

# Mailpit SMTP (self-hosted)
SMTP_HOST=192.168.1.2
SMTP_PORT=1025
EMAIL_FROM=noreply@hostamar.com

# MinIO S3-compatible storage (self-hosted)
S3_ENDPOINT=http://192.168.1.2:9000
S3_PUBLIC_URL=http://192.168.1.2:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=hostamar

# SSLCOMMERZ Payment Gateway
SSLCZ_STORE_ID=your-store-id
SSLCZ_STORE_PASSWD=your-store-password
SSLCZ_API_URL=https://sandbox.sslcommerz.com/gwprocess/v4/api.php
